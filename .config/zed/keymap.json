// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Workspace",
    "bindings": {
      // "space f": "file_finder::Toggle"
    }
  },
  {
    // VimControl == { "n", "x", "o" }
    "context": "VimControl && !menu",
    "bindings": {
      "h": "vim::WrappingLeft",
      "l": "vim::WrappingRight",
      "j": ["vim::Down", { "display_lines": true }],
      "k": ["vim::Up", { "display_lines": true }],
      "g w": "vim::HelixJumpToWord",
      "H": ["workspace::SendKeystrokes", "^"],
      "L": ["workspace::SendKeystrokes", "g _"],
      "M": ["workspace::SendKeystrokes", "%"],
      "ctrl-d": ["workspace::SendKeystrokes", "ctrl-d z z"],
      "ctrl-u": ["workspace::SendKeystrokes", "ctrl-u z z"],
      "n": ["workspace::SendKeystrokes", "n z z"],
      "N": ["workspace::SendKeystrokes", "N z z"],
      "J": ["workspace::SendKeystrokes", "m z J ` z"],
      "]r": "editor::GoToNextDocumentHighlight",
      "[r": "editor::GoToPreviousDocumentHighlight"
    }
  },
  {
    "context": "VimControl && !menu && vim_mode != operator",
    "bindings": {
      "b": "vim::PreviousSubwordStart",
      "e": "vim::NextSubwordEnd"
    }
  },
  {
    "context": "vim_operator == a || vim_operator == i || vim_operator == cs",
    "bindings": {
      "q": "vim::MiniQuotes",
      "b": "vim::MiniBrackets"
    }
  },
  {
    "context": "vim_mode == normal && !menu",
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-j": "workspace::ActivatePaneDown"
    }
  },
  {
    "context": "vim_mode == visual",
    "bindings": {
      ">": ["workspace::SendKeystrokes", "> g v"],
      "<": ["workspace::SendKeystrokes", "< g v"],
      "shift-s": "vim::PushAddSurrounds",
      "v": "editor::SelectLargerSyntaxNode",
      "ctrl-r": "editor::SelectSmallerSyntaxNode",
      "shift-x": "vim::Exchange"
    }
  },
  {
    "context": "vim_mode == insert",
    "unbind": {
      "ctrl-e": "vim::InsertFromBelow"
    }
  },
  {
    "context": "Terminal",
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft"
    }
  },
  {
    "context": "Dock && !Terminal",
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-j": "workspace::ActivatePaneDown"
    }
  },
  {
    "context": "Editor && showing_completions",
    "unbind": {
      "tab": "editor::ComposeCompletion"
    }
  }
]
