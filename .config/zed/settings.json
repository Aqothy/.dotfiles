{
  "git_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "project_panel": {
    "dock": "left"
  },
  "semantic_tokens": "combined",
  "relative_line_numbers": "enabled",
  "diagnostics": {
    "inline": {
      "enabled": true
    }
  },
  "agent_servers": {
    "codex-acp": {
      "type": "registry"
    },
    "gemini": {
      "type": "registry"
    }
  },
  "icon_theme": {
    "mode": "system",
    "light": "Material Icon Theme",
    "dark": "Material Icon Theme"
  },
  "edit_predictions": {
    "provider": "zed"
  },
  "agent": {
    "dock": "right",
    "default_profile": "write",
    "default_model": {
      "effort": "high",
      "enable_thinking": true,
      "provider": "zed.dev",
      "model": "gpt-5.4"
    }
  },
  "base_keymap": "VSCode",
  "telemetry": {
    "metrics": false,
    "diagnostics": false
  },
  "vim_mode": true,
  "buffer_font_family": "Hack Nerd Font Mono",
  "terminal": {
    "line_height": { "custom": 1.2 }
  },
  "vim": {
    "toggle_relative_line_numbers": true
  },
  "vertical_scroll_margin": 8,
  "theme": {
    "mode": "system",
    "light": "Gruvbox Light Soft",
    "dark": "Gruvbox Dark Soft"
  }
}
