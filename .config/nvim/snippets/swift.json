{
  "print": {
    "prefix": "l",
    "body": "print($0)",
    "description": "print(...)"
  },
  "swiftui-view": {
    "prefix": "view",
    "body": [
      "struct ${1:Name}: View {",
      "",
      "\tvar body: some View {",
      "\t\t$0",
      "\t}",
      "}"
    ],
    "description": "SwiftUI view declaration"
  },
  "header": {
    "prefix": "head",
    "body": [
      "//",
      "//  ${TM_FILENAME}",
      "//  ${WORKSPACE_NAME}",
      "//",
      "//  Created by Anthony Qiu on ${CURRENT_YEAR}-${CURRENT_MONTH}-${CURRENT_DATE}.",
      "//",
      ""
    ],
    "description": "header"
  }
}
