{
  "print": {
    "prefix": "l",
    "body": "print(\"$1\")\n$0",
    "description": "print(\"...\")"
  },
  "swiftui-view": {
    "prefix": "view",
    "body": [
      "import SwiftUI",
      "",
      "struct ${1:Name}: View {",
      "",
      "\tvar body: some View {",
      "\t\t$0",
      "\t}",
      "}",
      "",
      "#Preview {",
      "\t${1:Name}()",
      "}"
    ],
    "description": "SwiftUI view declaration"
  },
  "swiftdata-container": {
    "prefix": "sd",
    "body": [
      "private var sharedModelContainer: ModelContainer = {",
      "\tlet schema = Schema([${1:Model}.self])",
      "\tlet configuration = ModelConfiguration(schema: schema, isStoredInMemoryOnly: ${2:false})",
      "",
      "\tdo {",
      "\t\treturn try ModelContainer(for: schema, configurations: [configuration])",
      "\t} catch {",
      "\t\tfatalError(\"Failed to create ModelContainer: \\(error)\")",
      "\t}",
      "}()$0"
    ],
    "description": "SwiftData ModelContainer setup"
  },
  "header": {
    "prefix": "head",
    "body": [
      "//",
      "//  ${TM_FILENAME}",
      "//  ${WORKSPACE_NAME}",
      "//",
      "//  Created by $1 on ${CURRENT_YEAR}-${CURRENT_MONTH}-${CURRENT_DATE}.",
      "//",
      "$0"
    ],
    "description": "header"
  }
}
