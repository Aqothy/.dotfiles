# This is Git's per-user configuration file.
[user]
    email = aq0335@gmail.com
    name = Aqothy
# Please adapt and uncomment the following lines:
#   name = Anthony Qiu
#   email = aq0335@gmail.com

[core]
    excludesfile = ~/.gitignore_global
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    syntax-theme = gruvbox-dark

[column]
    ui = auto

[branch]
    sort = -committerdate

[credential]

[fetch]
    all = true
    prune = true

[push]
    autoSetupRemote = true
    followTags = true

[pull]
    rebase = true

[help]
    autocorrect = prompt

[commit]
    verbose = true

[diff]
    renames = true
    algorithm = histogram
    indentHeuristic = true
    colorMoved = plain
    mnemonicPrefix = true

[rebase]
    autoSquash = true
    autoStash = true
    updateRefs = true

[tag]
    sort = version:refname

[rerere]
    enabled = true
